ASPNETCORE_ENVIRONMENT=Production
DatabaseProvider=Postgres
DatabaseInitMode=EnsureCreated
DATABASE_URL=<Render External Database URL>

SeedData__Enabled=true
SeedData__AdminEmail=<admin-demo-email>
SeedData__AdminPassword=<admin-demo-password>
SeedData__AdminFullName=Demo Admin

Jwt__Key=<at-least-32-character-secret>
Jwt__Issuer=CosmeticShop
Jwt__Audience=CosmeticShop

Cors__AllowedOrigins=https://<frontend-service>.onrender.com,http://localhost:5173

EmailSettings__Mail=<gmail-address>
EmailSettings__Password=<gmail-app-password>
EmailSettings__Host=smtp.gmail.com
EmailSettings__Port=587
